{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "MoodEntry": {
      "title": "Mood Entry",
      "description": "A single mood tracking entry.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mood": { "type": "string" },
        "emoji": { "type": "string" },
        "intensity": { "type": "integer" },
        "note": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mood", "timestamp"]
    },
    "MeditationSession": {
      "title": "Meditation Session",
      "description": "Records of completed meditation sessions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "duration": { "type": "integer", "description": "Duration in seconds" },
        "technique": { "type": "string" },
        "moodBefore": { "type": "string" },
        "stressLevel": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "duration", "timestamp"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in the AI support chat.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/moods/{moodId}": {
      "schema": "MoodEntry",
      "description": "Mood tracking history"
    },
    "/meditations/{sessionId}": {
      "schema": "MeditationSession",
      "description": "Meditation history"
    },
    "/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "AI chat history"
    }
  }
}
